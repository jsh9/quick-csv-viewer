{
  "name": "quick-csv-viewer",
  "displayName": "Quick CSV Viewer",
  "description": "View and preview large CSV files in a readonly, fast VS Code custom editor.",
  "version": "0.0.1",
  "publisher": "jsh9",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsh9/quick-csv-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/jsh9/quick-csv-viewer/issues"
  },
  "homepage": "https://github.com/jsh9/quick-csv-viewer#readme",
  "keywords": [
    "csv",
    "csv-viewer",
    "large-files",
    "table",
    "custom-editor"
  ],
  "galleryBanner": {
    "color": "#1f6feb",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/src/extension.js",
  "activationEvents": [
    "onCustomEditor:quickCsvViewer.viewer",
    "onCommand:quickCsvViewer.openCurrentFile",
    "onCommand:quickCsvViewer.openSampleFiles"
  ],
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": false
  },
  "contributes": {
    "commands": [
      {
        "command": "quickCsvViewer.openCurrentFile",
        "title": "Open in Quick CSV Viewer",
        "category": "Quick CSV Viewer"
      }
    ],
    "languages": [
      {
        "id": "csv",
        "aliases": [
          "CSV",
          "csv"
        ],
        "extensions": [
          ".csv"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "quickCsvViewer.viewer",
        "displayName": "Quick CSV Viewer",
        "selector": [
          {
            "filenamePattern": "*.csv"
          },
          {
            "filenamePattern": "**/*.csv"
          }
        ],
        "priority": "default"
      }
    ],
    "configurationDefaults": {
      "workbench.editorAssociations": {
        "*.csv": "quickCsvViewer.viewer"
      }
    },
    "configuration": {
      "title": "Quick CSV Viewer",
      "properties": {
        "quickCsvViewer.maxRows": {
          "type": "integer",
          "default": 20,
          "minimum": 0,
          "description": "Number of CSV data rows to show. Set to 0 to index the full file and render visible rows on demand."
        },
        "quickCsvViewer.firstRowIsHeader": {
          "type": "boolean",
          "default": true,
          "description": "Treat the first CSV record as column headers and exclude it from the displayed row count."
        },
        "quickCsvViewer.wrapCellContents": {
          "type": "boolean",
          "default": true,
          "description": "Wrap CSV cell contents in the table view."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "quickCsvViewer.openCurrentFile"
        }
      ],
      "editor/title": [
        {
          "command": "quickCsvViewer.openCurrentFile",
          "when": "resourceExtname == .csv",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "quickCsvViewer.openCurrentFile",
          "when": "resourceExtname == .csv",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "prepare": "husky",
    "watch": "tsc -watch -p ./",
    "test": "npm run format:check && npm run compile && node scripts/run-tests.cjs",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "20.14.8",
    "@types/vscode": "1.90.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3"
  }
}
